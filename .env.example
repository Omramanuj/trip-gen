# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENROUTER_API_KEY: Required for Prompt Lab real LLM runs.
# Keep this server-side only. The frontend calls /api/prompt-lab/run.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# Fast model used for signal extraction, clarifying questions, outreach, and app-form drafts.
OPENROUTER_FAST_MODEL="openai/gpt-4o-mini"

# Stronger model used for six inferred cards / strategic reasoning.
OPENROUTER_STRATEGY_MODEL="openai/gpt-4o"

# Stronger model used for journey planning and lever content generation.
OPENROUTER_TRIP_MODEL="openai/gpt-4o"

# Optional request timeout.
OPENROUTER_TIMEOUT_MS="90000"

# OPENAI_API_KEY: Required for live role-brief transcription.
# Keep this server-side only. The frontend requests a short-lived Realtime token from /api/realtime/transcription-token.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_TRANSCRIBE_MODEL="gpt-4o-transcribe"
OPENAI_TRANSCRIBE_LANGUAGE="en"
OPENAI_TRANSCRIBE_SILENCE_MS="150"
OPENAI_TRANSCRIBE_VAD_THRESHOLD="0.5"
OPENAI_TRANSCRIBE_PREFIX_PADDING_MS="300"
# Optional. Leave unset unless needed; prompts can be echoed by the transcription model.
# OPENAI_TRANSCRIBE_PROMPT=""
