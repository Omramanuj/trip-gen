{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:prompt-lab": "node scripts/dev-prompt-lab.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prompts:check": "tsx scripts/check-prompts.ts",
    "prompts:render": "tsx scripts/render-prompts.ts",
    "eval:prompts": "npm run prompts:render && promptfoo eval -c evals/recruitment-os-prompts/promptfooconfig.yaml --no-cache",
    "eval:codex": "promptfoo eval -c evals/codex-app-server/promptfooconfig.yaml --no-cache",
    "eval:codex:view": "promptfoo view"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "promptfoo": "^0.121.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
